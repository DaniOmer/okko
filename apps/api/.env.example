# ─── Base de données (Prisma / PostgreSQL) ───────────────────────────────
# Correspond au service Postgres de docker-compose (okko/okko/okko).
DATABASE_URL="postgresql://okko:okko@localhost:5432/okko?schema=public"

# ─── Authentification (JWT) ──────────────────────────────────────────────
# Secret de signature des tokens. OBLIGATOIRE en production (l'app refuse de
# démarrer sans, en prod). En dev, un fallback "dev-secret" est utilisé si absent.
JWT_SECRET=change-me-in-production
# Durée de validité des tokens (défaut: 7d).
JWT_EXPIRES_IN=7d

# ─── Emails transactionnels (Brevo) ──────────────────────────────────────
# Clé API Brevo (https://app.brevo.com → SMTP & API → API Keys).
# Sans elle, les envois (invitations, confirmation d'inscription) échouent
# silencieusement (l'inscription reste créée, aucun email ne part).
BREVO_API_KEY=
# Adresse expéditrice VÉRIFIÉE dans Brevo (Senders & IP).
BREVO_SENDER=no-reply@ton-domaine.bj

# URL de base de l'admin, utilisée pour construire les liens d'invitation et
# de confirmation envoyés par email (ex: <INVITE_BASE_URL>/confirm/<token>).
INVITE_BASE_URL=http://localhost:3000

# ─── CORS ────────────────────────────────────────────────────────────────
# Origine autorisée à appeler l'API (l'app admin). Défaut dev: http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ─── Seed du superadmin (npx prisma db seed) ─────────────────────────────
# Compte superadmin créé au seed (confirmé d'office, peut se connecter).
SUPERADMIN_EMAIL=superadmin@okko.dev
SUPERADMIN_PASSWORD=change-me

# Storage S3-compatible (Cloudflare R2)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
# S3_FORCE_PATH_STYLE=true   # pour MinIO
